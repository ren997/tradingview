//@version=6
strategy(
     "BTC MA169 Trend Pullback Long",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.05
)

// 中文说明：
// 这是“趋势回踩 MA169 做多”的独立策略文件。
// 如果你现在准备继续专注优化 4 小时级别的回踩做多，最推荐从这个文件继续改。
// 它比 dual_mode 更干净，也比后面那些突破/洗盘实验版更贴近你当前认可的方向。

// ===== 参数 =====
maLen                  = input.int(169, "MA169长度", minval=1)
maTrendLen             = input.int(200, "MA200长度", minval=1)
atrLen                 = input.int(14, "ATR长度", minval=1)
maSlopeLookback        = input.int(10, "MA169上行确认根数", minval=1)
touchAtrTolerance      = input.float(0.20, "回踩贴近169容差(ATR倍数)", step=0.05, minval=0)
pullbackPierceAtr      = input.float(0.50, "回踩允许穿透169深度(ATR倍数)", step=0.05, minval=0)
minExtensionAtr        = input.float(2.0, "做多前至少拉离169多少ATR", step=0.1, minval=0.1)
signalCloseStrength    = input.float(0.55, "信号K收盘强度阈值", step=0.05, minval=0.1, maxval=1.0)
minExitReboundAtr      = input.float(1.0, "离场前至少再次拉离169多少ATR", step=0.1, minval=0.1)

signalStopAtrBuffer    = input.float(0.30, "信号K止损缓冲(ATR倍数)", step=0.05, minval=0)

enableLogs             = input.bool(false, "启用调试日志")
logPositionState       = input.bool(true, "记录持仓关键状态")
logRejectedCandidates  = input.bool(true, "记录候选信号被拦截原因")

// ===== 指标 =====
ma169        = ta.sma(close, maLen)
ma200        = ta.sma(close, maTrendLen)
atrValue     = ta.atr(atrLen)
safeAtrValue = math.max(atrValue, syminfo.mintick)
maRisingTrend = ma169 > ma169[maSlopeLookback]

plot(ma169, "MA169", color=color.green, linewidth=2)
plot(ma200, "MA200", color=color.red, linewidth=2)

// ===== 市场状态 =====
bullTrend = close > ma169 and ma169 > ma200 and maRisingTrend

// ===== 趋势回踩状态 =====
var bool firstTouchArmed = false
var bool touchEventActive = false
var bool firstTouchConsumed = false
var float maxExtensionSinceArmAtr = 0.0

bullTouch = low <= ma169 + atrValue * touchAtrTolerance and low >= ma169 - atrValue * pullbackPierceAtr and close > ma169
distanceFromMaAtr = math.max((high - ma169) / safeAtrValue, 0)
signalClosePct = (close - low) / math.max(high - low, syminfo.mintick)

if close < ma169
    firstTouchArmed := false
    touchEventActive := false
    firstTouchConsumed := false
    maxExtensionSinceArmAtr := 0.0
else if bullTrend and not firstTouchConsumed
    maxExtensionSinceArmAtr := math.max(maxExtensionSinceArmAtr, distanceFromMaAtr)
    if maxExtensionSinceArmAtr >= minExtensionAtr
        firstTouchArmed := true

firstTouchEvent = bullTrend and firstTouchArmed and bullTouch and not touchEventActive and not firstTouchConsumed
qualityFirstTouch = firstTouchEvent and signalClosePct >= signalCloseStrength

if firstTouchEvent
    firstTouchConsumed := true
    firstTouchArmed := false

if bullTouch
    touchEventActive := true
else if close > ma169 and high > ma169 + atrValue * touchAtrTolerance
    touchEventActive := false

longPullbackSignal =
     strategy.position_size == 0 and
     qualityFirstTouch

pullbackCandidate = strategy.position_size == 0 and bullTrend and bullTouch
extensionOk = maxExtensionSinceArmAtr >= minExtensionAtr
firstTouchEventOk = firstTouchEvent
closeStrengthOk = signalClosePct >= signalCloseStrength

if enableLogs and logRejectedCandidates and pullbackCandidate and not longPullbackSignal
    log.info(
         "候选回踩被拦截 | t={0} bullTouch={1} firstTouchEventOk={2} extensionOk={3} closeStrengthOk={4} maRisingTrend={5} extensionAtr={6} closeStrength={7} firstTouchConsumed={8}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         bullTouch,
         firstTouchEventOk,
         extensionOk,
         closeStrengthOk,
         maRisingTrend,
         maxExtensionSinceArmAtr,
         signalClosePct,
         firstTouchConsumed
    )

// ===== 仓位状态 =====
var float activeStop = na
var float signalLow = na
var int entryBarIndex = na
var bool exitRetouchArmed = false

// ===== 入场 =====
if longPullbackSignal
    signalLow := low
    activeStop := low - atrValue * signalStopAtrBuffer
    entryBarIndex := bar_index
    exitRetouchArmed := false
    firstTouchArmed := false
    touchEventActive := true
    firstTouchConsumed := true
    strategy.entry("Long", strategy.long, comment="Trend Pullback Long")
    strategy.exit("L-Stop", from_entry="Long", stop=activeStop)
    if enableLogs
        log.info(
             "趋势回踩做多 | t={0} signalLow={1} stop={2} closeStrength={3} extensionAtr={4}",
             str.format_time(time, "yyyy-MM-dd HH:mm"),
             signalLow,
             activeStop,
             signalClosePct,
             maxExtensionSinceArmAtr
        )

// ===== 持仓管理 =====
if strategy.position_size > 0 and not na(activeStop)
    if high >= ma169 + atrValue * minExitReboundAtr
        exitRetouchArmed := true
    touchExitSignal = exitRetouchArmed and not na(entryBarIndex) and bar_index > entryBarIndex and low <= ma169 + atrValue * touchAtrTolerance
    if touchExitSignal
        if enableLogs and logPositionState
            log.info(
                 "再次触碰169离场 | t={0} close={1} avgPrice={2} ma169={3} low={4} barsHeld={5}",
                 str.format_time(time, "yyyy-MM-dd HH:mm"),
                 close,
                 strategy.position_avg_price,
                 ma169,
                 low,
                 bar_index - entryBarIndex
            )
        strategy.close("Long", comment="Touch MA169 Exit")
    else if enableLogs and logPositionState
        log.info(
             "多单持仓状态 | t={0} close={1} avgPrice={2} activeStop={3} ma169={4} barsHeld={5} exitRetouchArmed={6}",
             str.format_time(time, "yyyy-MM-dd HH:mm"),
             close,
             strategy.position_avg_price,
             activeStop,
             ma169,
             bar_index - entryBarIndex,
             exitRetouchArmed
        )

// ===== 平仓后重置 =====
justClosedLong = strategy.position_size == 0 and strategy.position_size[1] > 0

if justClosedLong
    activeStop := na
    signalLow := na
    entryBarIndex := na
    exitRetouchArmed := false

// ===== 图形标记 =====
plotshape(longPullbackSignal, title="趋势回踩做多", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.small, text="PB多")
