//@version=6
strategy(
     "BTC MA169 Base Breakout Retest Long",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.05
)

// 中文说明：
// 这是“先在 MA169 附近震荡并放量突破，再等第一次回踩 MA169 做多”的独立策略。
// 突破定义沿用 base_breakout 版本；开仓与离场结构沿用回踩策略的风控思路。
// 关键约束是：突破后的第一次触碰 169 必须当根决定结果，要么开仓，要么失效。

// ===== 参数 =====
maLen                   = input.int(169, "MA169长度", minval=1)
maTrendLen              = input.int(200, "MA200长度", minval=1)
atrLen                  = input.int(14, "ATR长度", minval=1)
volumeLen               = input.int(20, "成交量均线长度", minval=1)
maSlopeLookback         = input.int(10, "MA169上行确认根数", minval=1)

baseLookback            = input.int(16, "震荡区回看K数", minval=5)
nearMaAtrMult           = input.float(1.20, "收盘贴近169阈值(ATR倍数)", step=0.05, minval=0.1)
allowBreakBelowAtr      = input.float(1.00, "允许跌破169最大深度(ATR倍数)", step=0.05, minval=0.1)
minNearMaRatio          = input.float(0.45, "贴近169收盘最小比例", step=0.05, minval=0.1, maxval=1.0)
minCloseAboveRatio      = input.float(0.50, "收在169上方最小比例", step=0.05, minval=0.1, maxval=1.0)
baseRangeAtrMax         = input.float(8.0, "震荡区最大总波动(ATR倍数)", step=0.25, minval=1.0)
baseCenterAtrMax        = input.float(1.80, "箱体中心偏离169最大距离(ATR倍数)", step=0.1, minval=0.1)
baseLowAtrMax           = input.float(1.40, "箱体下沿低于169最大距离(ATR倍数)", step=0.1, minval=0.1)
baseHighAtrMax          = input.float(4.80, "箱体上沿高于169最大距离(ATR倍数)", step=0.1, minval=0.1)
maxBreakoutWaitBars     = input.int(32, "冻结震荡区后等待突破K数", minval=1)
maxBreakoutAttempts     = input.int(3, "同一箱体最大突破尝试次数", minval=1)

breakoutVolumeMult      = input.float(1.30, "突破放量倍数", step=0.05, minval=0.1)
minBullBodyPct          = input.float(0.45, "突破K最小实体占比", step=0.05, minval=0.1, maxval=1.0)

touchAtrTolerance       = input.float(0.20, "回踩贴近169容差(ATR倍数)", step=0.05, minval=0)
pullbackPierceAtr       = input.float(0.50, "回踩允许穿透169深度(ATR倍数)", step=0.05, minval=0)
minExitReboundAtr       = input.float(1.0, "离场前至少再次拉离169多少ATR", step=0.1, minval=0.1)
signalStopAtrBuffer     = input.float(0.30, "信号K止损缓冲(ATR倍数)", step=0.05, minval=0)

enableLogs              = input.bool(true, "启用调试日志")
logBaseRejected         = input.bool(true, "记录震荡区被拦截原因")
logRejectedCandidates   = input.bool(true, "记录候选突破/回踩被拦截原因")
logPositionState        = input.bool(true, "记录持仓关键状态")
logProbeBars            = input.bool(true, "记录关键K判定日志")
logBaseArmEvents        = input.bool(true, "记录震荡区冻结事件")
logBaseSnapshots        = input.bool(true, "记录潜在震荡区快照")
logRetestState          = input.bool(true, "记录突破后等待回踩状态")

// ===== 指标 =====
ma169         = ta.sma(close, maLen)
ma200         = ta.sma(close, maTrendLen)
atrValue      = ta.atr(atrLen)
safeAtrValue  = math.max(atrValue, syminfo.mintick)
volumeAvg     = ta.sma(volume, volumeLen)
maRisingTrend = ma169 > ma169[maSlopeLookback]

plot(ma169, "MA169", color=color.green, linewidth=2)
plot(ma200, "MA200", color=color.red, linewidth=2)

// ===== 市场状态 =====
baseContext =
     close >= ma169 - atrValue * allowBreakBelowAtr and
     close <= ma169 + atrValue * nearMaAtrMult * 3.0

// ===== 震荡区识别 =====
nearMaCount = math.sum(math.abs(close[1] - ma169[1]) <= atrValue[1] * nearMaAtrMult ? 1.0 : 0.0, baseLookback)
closeAboveCount = math.sum(close[1] >= ma169[1] ? 1.0 : 0.0, baseLookback)
deepBreakCount = math.sum(close[1] < ma169[1] - atrValue[1] * allowBreakBelowAtr ? 1.0 : 0.0, baseLookback)

nearMaRatio = nearMaCount / baseLookback
closeAboveRatio = closeAboveCount / baseLookback
baseHigh = ta.highest(high[1], baseLookback)
baseLow = ta.lowest(low[1], baseLookback)
baseCenter = (baseHigh + baseLow) / 2.0
baseRangeAtr = (baseHigh - baseLow) / safeAtrValue
baseCenterAtr = math.abs(baseCenter - ma169) / safeAtrValue
baseLowAtr = math.max(ma169 - baseLow, 0) / safeAtrValue
baseHighAtr = math.max(baseHigh - ma169, 0) / safeAtrValue

baseReady =
     baseContext and
     baseRangeAtr <= baseRangeAtrMax and
     baseCenterAtr <= baseCenterAtrMax and
     baseLowAtr <= baseLowAtrMax and
     baseHighAtr <= baseHighAtrMax

var bool retestPending = false
var int pendingBreakoutBarIndex = na
var float pendingBreakoutHigh = na
var float pendingBreakoutLow = na
var int pendingBreakoutAttempt = na

baseCandidate =
     strategy.position_size == 0 and
     not retestPending and
     baseContext and
     math.abs(close - ma169) <= atrValue * nearMaAtrMult * 2.0

baseSnapshotCandidate =
     strategy.position_size == 0 and
     not retestPending and
     (
         closeAboveRatio >= math.max(minCloseAboveRatio * 0.7, 0.35) or
         nearMaRatio >= math.max(minNearMaRatio * 0.7, 0.35)
     ) and
     baseRangeAtr <= baseRangeAtrMax * 1.35

if enableLogs and logBaseRejected and baseCandidate and not baseReady
    log.info(
         "震荡区被拦截 | t={0} nearMaRatio={1} closeAboveRatio={2} deepBreakCount={3} baseRangeAtr={4} baseCenterAtr={5} baseLowAtr={6} baseHighAtr={7} baseContext={8} ma169={9} ma200={10} maRisingTrend={11}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         nearMaRatio,
         closeAboveRatio,
         deepBreakCount,
         baseRangeAtr,
         baseCenterAtr,
         baseLowAtr,
         baseHighAtr,
         baseContext,
         ma169,
         ma200,
         maRisingTrend
    )

if enableLogs and logBaseSnapshots and baseSnapshotCandidate
    log.info(
         "潜在震荡区快照 | t={0} baseContext={1} baseReady={2} nearMaRatio={3} closeAboveRatio={4} deepBreakCount={5} baseRangeAtr={6} baseCenterAtr={7} baseLowAtr={8} baseHighAtr={9} baseHigh={10} baseLow={11} ma169={12} ma200={13}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         baseContext,
         baseReady,
         nearMaRatio,
         closeAboveRatio,
         deepBreakCount,
         baseRangeAtr,
         baseCenterAtr,
         baseLowAtr,
         baseHighAtr,
         baseHigh,
         baseLow,
         ma169,
         ma200
    )

// ===== 突破信号 =====
barRange = math.max(high - low, syminfo.mintick)
bullBodyPct = (close - open) / barRange
volumeOk = volume > volumeAvg * breakoutVolumeMult

// ===== 仓位与状态 =====
var float activeStop = na
var float signalLow = na
var int entryBarIndex = na
var bool exitRetouchArmed = false

var bool baseArmed = false
var float armedBaseHigh = na
var float armedBaseLow = na
var float armedNearMaRatio = na
var float armedCloseAboveRatio = na
var int armedBaseBarIndex = na
var int armedDeepBreakCount = na
var float armedBaseRangeAtr = na
var float armedBaseCenterAtr = na
var float armedBaseLowAtr = na
var float armedBaseHighAtr = na
var int armedAttemptCount = 0

// ===== 冻结震荡区 =====
if strategy.position_size == 0 and not retestPending and baseReady
    refreshedExistingBase = baseArmed
    baseArmed := true
    armedBaseHigh := baseHigh
    armedBaseLow := baseLow
    armedNearMaRatio := nearMaRatio
    armedCloseAboveRatio := closeAboveRatio
    armedBaseBarIndex := bar_index
    armedDeepBreakCount := int(deepBreakCount)
    armedBaseRangeAtr := baseRangeAtr
    armedBaseCenterAtr := baseCenterAtr
    armedBaseLowAtr := baseLowAtr
    armedBaseHighAtr := baseHighAtr
    if not refreshedExistingBase
        armedAttemptCount := 0
    if enableLogs and logBaseArmEvents
        log.info(
             "冻结震荡区 | t={0} refreshedExistingBase={1} armedBaseHigh={2} armedBaseLow={3} nearMaRatio={4} closeAboveRatio={5} deepBreakCount={6} baseRangeAtr={7} baseCenterAtr={8} baseLowAtr={9} baseHighAtr={10} attemptCount={11} barsLookback={12}",
             str.format_time(time, "yyyy-MM-dd HH:mm"),
             refreshedExistingBase,
             armedBaseHigh,
             armedBaseLow,
             armedNearMaRatio,
             armedCloseAboveRatio,
             armedDeepBreakCount,
             armedBaseRangeAtr,
             armedBaseCenterAtr,
             armedBaseLowAtr,
             armedBaseHighAtr,
             armedAttemptCount,
             baseLookback
        )

armedTimedOut = baseArmed and not na(armedBaseBarIndex) and bar_index - armedBaseBarIndex > maxBreakoutWaitBars
armedDeepBreakNow = baseArmed and close < ma169 - atrValue * allowBreakBelowAtr
armedAttemptsExceeded = baseArmed and armedAttemptCount >= maxBreakoutAttempts

if strategy.position_size == 0 and not retestPending and (armedTimedOut or armedDeepBreakNow or armedAttemptsExceeded)
    if enableLogs and logProbeBars and baseArmed
        log.info(
             "冻结震荡区失效 | t={0} armedTimedOut={1} armedDeepBreakNow={2} armedAttemptsExceeded={3} barsSinceArmed={4} armedBaseHigh={5} armedBaseLow={6} attemptCount={7} ma169={8} low={9}",
             str.format_time(time, "yyyy-MM-dd HH:mm"),
             armedTimedOut,
             armedDeepBreakNow,
             armedAttemptsExceeded,
             bar_index - armedBaseBarIndex,
             armedBaseHigh,
             armedBaseLow,
             armedAttemptCount,
             ma169,
             low
        )
    baseArmed := false
    armedBaseHigh := na
    armedBaseLow := na
    armedNearMaRatio := na
    armedCloseAboveRatio := na
    armedBaseBarIndex := na
    armedDeepBreakCount := na
    armedBaseRangeAtr := na
    armedBaseCenterAtr := na
    armedBaseLowAtr := na
    armedBaseHighAtr := na
    armedAttemptCount := 0

// ===== 突破后等待回踩 =====
breakoutBarArmed = baseArmed and close > armedBaseHigh and close > open and bullBodyPct >= minBullBodyPct
breakoutCandidate = strategy.position_size == 0 and not retestPending and baseArmed and close >= armedBaseHigh * 0.995
probeCandidate =
     strategy.position_size == 0 and
     (
         baseReady or
         baseCandidate or
         baseArmed or
         breakoutCandidate or
         retestPending
     )
breakoutSignal =
     strategy.position_size == 0 and
     not retestPending and
     baseArmed and
     armedAttemptCount < maxBreakoutAttempts and
     breakoutBarArmed and
     volumeOk

if enableLogs and logRejectedCandidates and breakoutCandidate and not breakoutSignal
    log.info(
         "候选突破被拦截 | t={0} baseArmed={1} volumeOk={2} breakoutBar={3} armedBaseHigh={4} armedBaseLow={5} armedNearMaRatio={6} armedCloseAboveRatio={7} armedDeepBreakCount={8} armedBaseRangeAtr={9} armedBaseCenterAtr={10} armedBaseLowAtr={11} armedBaseHighAtr={12} attemptCount={13}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         baseArmed,
         volumeOk,
         breakoutBarArmed,
         armedBaseHigh,
         armedBaseLow,
         armedNearMaRatio,
         armedCloseAboveRatio,
         armedDeepBreakCount,
         armedBaseRangeAtr,
         armedBaseCenterAtr,
         armedBaseLowAtr,
         armedBaseHighAtr,
         armedAttemptCount
    )

if enableLogs and logProbeBars and probeCandidate
    log.info(
         "关键K评估 | t={0} baseContext={1} baseReady={2} baseArmed={3} breakoutCandidate={4} breakoutSignal={5} volumeOk={6} breakoutBar={7} retestPending={8} pendingBreakoutBarIndex={9} close={10} ma169={11} ma200={12} nearMaRatio={13} closeAboveRatio={14} deepBreakCount={15}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         baseContext,
         baseReady,
         baseArmed,
         breakoutCandidate,
         breakoutSignal,
         volumeOk,
         breakoutBarArmed,
         retestPending,
         pendingBreakoutBarIndex,
         close,
         ma169,
         ma200,
         nearMaRatio,
         closeAboveRatio,
         deepBreakCount
    )

if breakoutSignal
    pendingBreakoutHigh := armedBaseHigh
    pendingBreakoutLow := armedBaseLow
    pendingBreakoutAttempt := armedAttemptCount + 1
    pendingBreakoutBarIndex := bar_index
    retestPending := true
    baseArmed := false
    armedBaseHigh := na
    armedBaseLow := na
    armedNearMaRatio := na
    armedCloseAboveRatio := na
    armedBaseBarIndex := na
    armedDeepBreakCount := na
    armedBaseRangeAtr := na
    armedBaseCenterAtr := na
    armedBaseLowAtr := na
    armedBaseHighAtr := na
    armedAttemptCount := 0
    if enableLogs and logRetestState
        log.info(
             "震荡突破确认，开始等待首次回踩 | t={0} breakoutBarIndex={1} pendingBreakoutHigh={2} pendingBreakoutLow={3} pendingBreakoutAttempt={4}",
             str.format_time(time, "yyyy-MM-dd HH:mm"),
             pendingBreakoutBarIndex,
             pendingBreakoutHigh,
             pendingBreakoutLow,
             pendingBreakoutAttempt
        )

retestTouchZone = low <= ma169 + atrValue * touchAtrTolerance
retestValidPierce = low >= ma169 - atrValue * pullbackPierceAtr
firstRetestTouch =
     strategy.position_size == 0 and
     retestPending and
     not na(pendingBreakoutBarIndex) and
     bar_index > pendingBreakoutBarIndex and
     retestTouchZone

longRetestSignal =
     firstRetestTouch and
     retestValidPierce and
     close > ma169

retestFailed = firstRetestTouch and not longRetestSignal

if enableLogs and logRejectedCandidates and firstRetestTouch and retestFailed
    log.info(
         "首次回踩失效 | t={0} close={1} ma169={2} retestValidPierce={3} low={4} pendingBreakoutHigh={5} pendingBreakoutLow={6}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         close,
         ma169,
         retestValidPierce,
         low,
         pendingBreakoutHigh,
         pendingBreakoutLow
    )

// ===== 入场 =====
if longRetestSignal
    entryPendingAttempt = pendingBreakoutAttempt
    signalLow := low
    activeStop := low - atrValue * signalStopAtrBuffer
    entryBarIndex := bar_index
    exitRetouchArmed := false
    retestPending := false
    pendingBreakoutBarIndex := na
    pendingBreakoutHigh := na
    pendingBreakoutLow := na
    pendingBreakoutAttempt := na
    strategy.entry("Long", strategy.long, comment="Breakout Retest Long")
    strategy.exit("L-Stop", from_entry="Long", stop=activeStop)
    if enableLogs and logRetestState
        log.info(
             "突破后首次回踩做多 | t={0} signalLow={1} stop={2} pendingBreakoutAttempt={3}",
             str.format_time(time, "yyyy-MM-dd HH:mm"),
             signalLow,
             activeStop,
             entryPendingAttempt
        )
else if retestFailed
    retestPending := false
    pendingBreakoutBarIndex := na
    pendingBreakoutHigh := na
    pendingBreakoutLow := na
    pendingBreakoutAttempt := na

// ===== 持仓管理 =====
if strategy.position_size > 0 and not na(activeStop)
    if high >= ma169 + atrValue * minExitReboundAtr
        exitRetouchArmed := true
    touchExitSignal = exitRetouchArmed and not na(entryBarIndex) and bar_index > entryBarIndex and low <= ma169 + atrValue * touchAtrTolerance
    if touchExitSignal
        if enableLogs and logPositionState
            log.info(
                 "再次触碰169离场 | t={0} close={1} avgPrice={2} ma169={3} low={4} barsHeld={5}",
                 str.format_time(time, "yyyy-MM-dd HH:mm"),
                 close,
                 strategy.position_avg_price,
                 ma169,
                 low,
                 bar_index - entryBarIndex
            )
        strategy.close("Long", comment="Touch MA169 Exit")
    else if enableLogs and logPositionState
        log.info(
             "多单持仓状态 | t={0} close={1} avgPrice={2} activeStop={3} ma169={4} barsHeld={5} exitRetouchArmed={6}",
             str.format_time(time, "yyyy-MM-dd HH:mm"),
             close,
             strategy.position_avg_price,
             activeStop,
             ma169,
             bar_index - entryBarIndex,
             exitRetouchArmed
        )

// ===== 平仓后重置 =====
justClosedLong = strategy.position_size == 0 and strategy.position_size[1] > 0

if justClosedLong
    activeStop := na
    signalLow := na
    entryBarIndex := na
    exitRetouchArmed := false

// ===== 图形标记 =====
bgcolor(retestPending ? color.new(color.orange, 88) : baseReady ? color.new(color.blue, 92) : na, title="状态背景")
plotshape(breakoutSignal, title="震荡突破待回踩", style=shape.circle, location=location.abovebar, color=color.orange, size=size.tiny, text="待PB")
plotshape(longRetestSignal, title="突破后回踩做多", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.small, text="PB多")
plotshape(retestFailed, title="首次回踩失效", style=shape.xcross, location=location.abovebar, color=color.red, size=size.tiny, text="失效")
