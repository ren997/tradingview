//@version=6
strategy(
     "MA169调试版_突破后前N次有效回踩",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100,
     commission_type=strategy.commission.percent,
     commission_value=0.05
)

// ===== 参数 =====
maFastLen          = input.int(169, "当前周期MA169")
maSlowLen          = input.int(200, "当前周期MA200")
minGapPct          = input.float(0.30, "MA169高于MA200最小间距(%)", step=0.01) / 100
cooldownBars       = input.int(5, "平仓后冷却K线数", minval=0)
requireSlopeUp     = input.bool(true, "要求当前周期MA169连续向上")

minMovePct         = input.float(1.0, "激活回踩出场的最小浮盈(%)", step=0.1) / 100
exitBufferPct      = input.float(0.10, "跌破当前周期MA169出场缓冲(%)", step=0.01) / 100
minHoldBars        = input.int(2, "最少持仓K数", minval=0)

maxPullbacksAfterBreak = input.int(3, "突破后最多允许第几次有效回踩内入场", minval=1)
use3DFilter            = input.bool(false, "启用3日线MA169过滤")
atrLen                 = input.int(14, "ATR长度", minval=1)
pullbackAtrBufferMult  = input.float(0.5, "回踩允许跌破MA169的ATR倍数", step=0.1, minval=0)
stopAtrMult            = input.float(0.5, "结构止损ATR缓冲倍数", step=0.1, minval=0)
tp1RR                  = input.float(1.0, "第一止盈RR", step=0.1, minval=0.1)
tp1QtyPct              = input.float(40.0, "第一止盈仓位(%)", step=1, minval=1, maxval=99)
moveStopToBreakeven    = input.bool(true, "第一止盈后剩余仓位提保本")
enableDebugLogs        = input.bool(true, "启用目标日期诊断日志")
debugYear              = input.int(2024, "诊断目标年", minval=1970)
debugMonth             = input.int(11, "诊断目标月", minval=1, maxval=12)
debugDay               = input.int(4, "诊断目标日", minval=1, maxval=31)
debugHour              = input.int(8, "诊断目标小时", minval=0, maxval=23)
debugMinute            = input.int(0, "诊断目标分钟", minval=0, maxval=59)
enableSecondTarget     = input.bool(true, "启用第二重点时刻")
debugYear2             = input.int(2024, "第二重点年", minval=1970)
debugMonth2            = input.int(11, "第二重点月", minval=1, maxval=12)
debugDay2              = input.int(5, "第二重点日", minval=1, maxval=31)
debugHour2             = input.int(4, "第二重点小时", minval=0, maxval=23)
debugMinute2           = input.int(0, "第二重点分钟", minval=0, maxval=59)
debugHoursBefore       = input.int(12, "诊断窗口前置小时", minval=0)
debugHoursAfter        = input.int(12, "诊断窗口后置小时", minval=0)

// ===== 当前周期均线 =====
ma169 = ta.sma(close, maFastLen)
ma200 = ta.sma(close, maSlowLen)

plot(ma169, "当前周期MA169", color=color.green, linewidth=2)
plot(ma200, "当前周期MA200", color=color.red, linewidth=2)

// ===== 多周期 MA169 =====
ma169_1d  = request.security(syminfo.tickerid, "D", ta.sma(close, 169))
ma200_1d  = request.security(syminfo.tickerid, "D", ta.sma(close, 200))
ma169_3d  = request.security(syminfo.tickerid, "3D", ta.sma(close, 169))
atrValue  = ta.atr(atrLen)

// ===== 趋势过滤 =====
trendBase = ma169 > ma200
trendGap  = (ma169 - ma200) / ma200 > minGapPct
slopeUp   = ma169 > ma169[1] and ma169[1] > ma169[2]
trendOk   = trendBase and trendGap and (requireSlopeUp ? slopeUp : true)

// ===== 日线趋势过滤 =====
dailyTrendBase = ma169_1d > ma200_1d
dailySlopeUp   = ma169_1d > ma169_1d[1] and ma169_1d[1] > ma169_1d[2]
daily3DFilterOk = not use3DFilter or close > ma169_3d
dailyTrendOk   = dailyTrendBase and dailySlopeUp and daily3DFilterOk
slopeRuleOk    = not requireSlopeUp or slopeUp

// ===== 冷却机制 =====
var int lastExitBar = na
canEnter = na(lastExitBar) or (bar_index - lastExitBar > cooldownBars)

// ===== 突破 + 有效回踩 =====
crossUp169    = close[1] < ma169[1] and close > ma169
pullbackDepthOk = low >= ma169 - atrValue * pullbackAtrBufferMult
validPullback = low < ma169 and close > ma169 and pullbackDepthOk

// 状态机
var bool waitingPullback = false
var int  pullbackCount   = 0

if crossUp169
    waitingPullback := true
    pullbackCount   := 0
    log.info(
         "突破169 | t={0} close={1} ma169={2} ma200={3}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         close, ma169, ma200
    )

newValidPullback = waitingPullback and validPullback and not validPullback[1]

if newValidPullback
    pullbackCount += 1
    log.info(
         "有效回踩#{0} | t={1} low={2} close={3} ma169={4} waiting={5}",
         pullbackCount,
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         low, close, ma169, waitingPullback
    )

entryWindowOk = waitingPullback and pullbackCount > 0 and pullbackCount <= maxPullbacksAfterBreak

longCondition = entryWindowOk and trendOk and dailyTrendOk and canEnter and validPullback

positionFlat = strategy.position_size == 0
actualEntryReady = longCondition and positionFlat
gapPctNow = (ma169 - ma200) / ma200
dailyGapPctNow = (ma169_1d - ma200_1d) / ma200_1d
debugHourMs = 60 * 60 * 1000
debugCenterTs = timestamp(debugYear, debugMonth, debugDay, debugHour, debugMinute)
debugCenterTs2 = timestamp(debugYear2, debugMonth2, debugDay2, debugHour2, debugMinute2)
debugWindowStartTs = debugCenterTs - debugHoursBefore * debugHourMs
debugWindowEndTs = debugCenterTs + debugHoursAfter * debugHourMs
debugWindowStartTs2 = debugCenterTs2 - debugHoursBefore * debugHourMs
debugWindowEndTs2 = debugCenterTs2 + debugHoursAfter * debugHourMs
inPrimaryDebugWindow = enableDebugLogs and time >= debugWindowStartTs and time < debugWindowEndTs
inSecondDebugWindow = enableDebugLogs and enableSecondTarget and time >= debugWindowStartTs2 and time < debugWindowEndTs2
inDebugWindow = inPrimaryDebugWindow or inSecondDebugWindow
isTargetBar = enableDebugLogs and time == debugCenterTs
isSecondTargetBar = enableDebugLogs and enableSecondTarget and time == debugCenterTs2
targetTag =
     isTargetBar ? "target-1" :
     isSecondTargetBar ? "target-2" :
     inPrimaryDebugWindow ? "window-1" :
     inSecondDebugWindow ? "window-2" :
     "none"

entryFailReason =
     not waitingPullback ? "waitingPullback=false(尚未出现突破或这轮突破已失效)" :
     pullbackCount == 0 ? "pullbackCount=0(突破后还没等到首个有效回踩)" :
     pullbackCount > maxPullbacksAfterBreak ? "pullbackCount超限(已超过允许回踩次数)" :
     not trendBase ? "trendBase=false(MA169没有站上MA200)" :
     not trendGap ? "trendGap=false(MA169与MA200间距不足)" :
     not slopeRuleOk ? "slopeRuleOk=false(MA169没有连续上升)" :
     not dailyTrendBase ? "dailyTrendBase=false(日线MA169没有站上日线MA200)" :
     not dailySlopeUp ? "dailySlopeUp=false(日线MA169没有连续上升)" :
     not daily3DFilterOk ? "daily3DFilterOk=false(价格低于3日MA169)" :
     not canEnter ? "canEnter=false(还在冷却期)" :
     not pullbackDepthOk ? "pullbackDepthOk=false(回踩跌破MA169过深)" :
     not validPullback ? "validPullback=false(当前K线不是有效回踩)" :
     not positionFlat ? "positionFlat=false(当时已有持仓)" :
     "满足开仓条件"

// ===== 关键日志：每次有效回踩都打印各条件 =====
if newValidPullback
    log.info(
         "检查入场 | t={0} pullbackCount={1} entryWindowOk={2} trendOk={3} dailyTrendOk={4} canEnter={5} validPullback={6} pullbackDepthOk={7} close={8} ma169={9} ma200={10} atr={11} ma1d={12} ma200_1d={13} ma3d={14}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         pullbackCount,
         entryWindowOk,
         trendOk,
         dailyTrendOk,
         canEnter,
         validPullback,
         pullbackDepthOk,
         close,
         ma169,
         ma200,
         atrValue,
         ma169_1d,
         ma200_1d,
         ma169_3d
    )

// ===== 目标日期前后诊断日志 =====
if inDebugWindow
    log.info(
         "诊断K线 | t={0} tag={1} targetBar={2} secondTargetBar={3} open={4} high={5} low={6} close={7} ma169={8} ma200={9} gapPct={10}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         targetTag,
         isTargetBar,
         isSecondTargetBar,
         open, high, low, close,
         ma169, ma200, gapPctNow * 100
    )
    log.info(
         "诊断状态 | t={0} crossUp169={1} newValidPullback={2} validPullback={3} waitingPullback={4} pullbackCount={5} entryWindowOk={6} canEnter={7} lastExitBar={8} positionSize={9}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         crossUp169,
         newValidPullback,
         validPullback,
         waitingPullback,
         pullbackCount,
         entryWindowOk,
         canEnter,
         lastExitBar,
         strategy.position_size
    )
    log.info(
         "诊断过滤 | t={0} trendBase={1} trendGap={2} slopeUp={3} slopeRuleOk={4} trendOk={5} dailyTrendBase={6} dailySlopeUp={7} daily3DFilterOk={8} dailyTrendOk={9} pullbackDepthOk={10} atr={11} dailyGapPct={12}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         trendBase,
         trendGap,
         slopeUp,
         slopeRuleOk,
         trendOk,
         dailyTrendBase,
         dailySlopeUp,
         daily3DFilterOk,
         dailyTrendOk,
         pullbackDepthOk,
         atrValue,
         dailyGapPctNow * 100
    )
    log.info(
         "诊断结论 | t={0} longCondition={1} positionFlat={2} actualEntryReady={3} failReason={4}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         longCondition,
         positionFlat,
         actualEntryReady,
         entryFailReason
    )

if isTargetBar or isSecondTargetBar
    log.info(
         "目标时刻总结 | t={0} tag={1} crossUp169={2} newValidPullback={3} waitingPullback={4} pullbackCount={5} trendBase={6} trendGap={7} slopeUp={8} dailyTrendOk={9} canEnter={10} positionFlat={11} actualEntryReady={12} failReason={13}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         targetTag,
         crossUp169,
         newValidPullback,
         waitingPullback,
         pullbackCount,
         trendBase,
         trendGap,
         slopeUp,
         dailyTrendOk,
         canEnter,
         positionFlat,
         actualEntryReady,
         entryFailReason
    )

// ===== 入场 =====
var float signalLow = na
var float plannedStopPrice = na
var float entryRisk = na
var float tp1Price = na
var bool  tp1Hit = false

if actualEntryReady
    signalLow := low
    plannedStopPrice := signalLow - atrValue * stopAtrMult
    strategy.entry("Long", strategy.long)
    strategy.exit("SL", from_entry="Long", stop=plannedStopPrice)
    waitingPullback := false
    pullbackCount := 0
    tp1Hit := false
    log.info(
         "准备开仓 | t={0} signalLow={1} plannedStop={2} close={3} atr={4} stopAtrMult={5} riskVsClosePct={6}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         signalLow,
         plannedStopPrice,
         close,
         atrValue,
         stopAtrMult,
         (close - plannedStopPrice) / close * 100
    )
    log.info(
         "预埋止损 | t={0} stopPrice={1} fromSignalLow={2}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         plannedStopPrice,
         signalLow
    )

if waitingPullback and pullbackCount > maxPullbacksAfterBreak
    log.info(
         "放弃这轮突破 | t={0} pullbackCount={1} 超过限制={2}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         pullbackCount,
         maxPullbacksAfterBreak
    )
    waitingPullback := false
    pullbackCount := 0

// ===== 止损 =====
if strategy.position_size > 0 and not na(signalLow)
    entryRisk := strategy.position_avg_price - plannedStopPrice
    tp1Price := strategy.position_avg_price + entryRisk * tp1RR
    if high >= tp1Price
        tp1Hit := true
    runnerStopPrice = moveStopToBreakeven and tp1Hit ? strategy.position_avg_price : plannedStopPrice
    strategy.exit("TP1", from_entry="Long", limit=tp1Price, stop=plannedStopPrice, qty_percent=tp1QtyPct)
    strategy.exit("SL", from_entry="Long", stop=runnerStopPrice, qty_percent=100 - tp1QtyPct)
    if strategy.position_size[1] <= 0
        log.info(
             "持仓风控已生效 | t={0} avgPrice={1} signalLow={2} initialStop={3} runnerStop={4} tp1Price={5} entryRiskPct={6} high={7} low={8} close={9}",
             str.format_time(time, "yyyy-MM-dd HH:mm"),
             strategy.position_avg_price,
             signalLow,
             plannedStopPrice,
             runnerStopPrice,
             tp1Price,
             entryRisk / strategy.position_avg_price * 100,
             high,
             low,
             close
        )
    if tp1Hit and not tp1Hit[1]
        log.info(
             "第一止盈已触发 | t={0} avgPrice={1} tp1Price={2} runnerStop={3}",
             str.format_time(time, "yyyy-MM-dd HH:mm"),
             strategy.position_avg_price,
             tp1Price,
             runnerStopPrice
        )

// ===== 出场 =====
hasPosition    = strategy.position_size > 0 and strategy.opentrades > 0
entryBar       = hasPosition ? strategy.opentrades.entry_bar_index(0) : na
enoughBarsHeld = hasPosition and (bar_index - entryBar >= minHoldBars)
movedEnough    = hasPosition and high >= strategy.position_avg_price * (1 + minMovePct)

touchMaExit = hasPosition and enoughBarsHeld and tp1Hit and movedEnough and low <= ma169 * (1 - exitBufferPct)

if touchMaExit
    strategy.close("Long", comment="Runner Touch Current TF MA169")
    log.info(
         "Runner触发出场 | t={0} low={1} ma169={2} avgPrice={3} tp1Hit={4}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         low, ma169, strategy.position_avg_price, tp1Hit
    )

// ===== 平仓后重置 =====
justClosed = strategy.position_size == 0 and strategy.position_size[1] > 0
if justClosed
    log.info(
         "平仓回顾 | t={0} prevAvgPrice={1} prevSignalLow={2} prevPlannedStop={3} prevTp1Price={4} prevTp1Hit={5} exitBarOpen={6} exitBarHigh={7} exitBarLow={8} exitBarClose={9}",
         str.format_time(time, "yyyy-MM-dd HH:mm"),
         strategy.position_avg_price[1],
         signalLow[1],
         plannedStopPrice[1],
         tp1Price[1],
         tp1Hit[1],
         open,
         high,
         low,
         close
    )
    signalLow := na
    plannedStopPrice := na
    entryRisk := na
    tp1Price := na
    tp1Hit := false
    lastExitBar := bar_index
    log.info(
         "已平仓并重置 | t={0}",
         str.format_time(time, "yyyy-MM-dd HH:mm")
    )

// ===== 图上标记 =====
plotshape(crossUp169, title="突破169", style=shape.circle, location=location.belowbar, color=color.blue, size=size.tiny, text="突")
plotshape(newValidPullback, title="有效回踩", style=shape.circle, location=location.belowbar, color=color.white, size=size.tiny, text="回")
plotshape(longCondition, title="买入信号", style=shape.triangleup, location=location.belowbar, color=color.yellow, size=size.small, text="买")
plotshape(touchMaExit, title="出场信号", style=shape.triangledown, location=location.abovebar, color=color.aqua, size=size.small, text="卖")

if newValidPullback
    label.new(
         bar_index,
         low,
         "PB" + str.tostring(pullbackCount),
         style=label.style_label_up,
         textcolor=color.black,
         color=color.white,
         size=size.tiny
    )
